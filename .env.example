# BROskiPets — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Redis (REQUIRED — no default)
REDIS_PASSWORD=change_me_to_something_strong

# LLM
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=3

# API
CHAT_COOLDOWN_SECONDS=6
ALLOWED_ORIGINS=http://localhost:3000

# Monitoring
GRAFANA_PASSWORD=change_me_grafana

# Redis pool
REDIS_MAX_CONNECTIONS=50
