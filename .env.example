# BROskiPets — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=bropets_secret_change_me_in_production

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Model to use — qwen2.5:7b is the default (4 GB download on first run)
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://ollama:11434

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Required for uploading pet metadata and images to IPFS.
# Get a free JWT at: https://app.pinata.cloud/developers/api-keys
# Without this, metadata uploads will fail (falls back to local upload)
PINATA_JWT=

# Root CID of the pet images folder on IPFS (optional)
# If set, metadata will link to ipfs://{IMAGES_ROOT_CID}/species/stage.png
IMAGES_ROOT_CID=

# IPFS gateway for resolving CIDs in the browser
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Blockchain (Sepolia testnet) ──────────────────────────────────────────────
# RPC endpoint for Sepolia (get free key at alchemy.com or infura.io)
# Examples:
#   https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
#   https://sepolia.infura.io/v3/YOUR_PROJECT_ID
SEPOLIA_RPC=

# Deployer/Agent wallet private key (format: 0x-prefixed 64-char hex)
# NEVER use a mainnet wallet with real funds here — testnet only!
# Get free Sepolia ETH at: https://www.sepoliafaucet.com
DEPLOYER_KEY=
AGENT_KEY=

# Deployed EEPVengers contract address on Sepolia (fill after deployment)
CONTRACT_ADDRESS=

# ── Rewards System ────────────────────────────────────────────────────────────
# Admin token for /rewards/award endpoint (strong random string)
REWARDS_ADMIN_TOKEN=

# ── Optional: Feature Flags ────────────────────────────────────────────────────
# DEBUG_MODE=false
# LOG_LEVEL=INFO
