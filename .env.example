# BROskiPets — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Model to use — qwen2.5:7b is the default (4 GB download on first run)
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://ollama:11434

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Required for uploading pet metadata and images to IPFS.
# Get a free JWT at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# IPFS gateway for resolving CIDs in the browser
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Blockchain (for contract deployment) ──────────────────────────────────────
# RPC URL for Sepolia testnet (get one free at alchemy.com or infura.io)
SEPOLIA_RPC=

# Deployer wallet private key — NEVER use a mainnet wallet with real funds here
DEPLOYER_KEY=

# Deployed contract address (fill after deployment)
CONTRACT_ADDRESS=

AGENT_KEY=
